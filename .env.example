# PostgreSQL connection string used by Prisma
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Redis connection string used by caching and rate limiting
REDIS_URL="redis://:PASSWORD@HOST:6379"

# JWT signing secret used for auth tokens
JWT_SECRET="supersecretjwtkey"

# Stellar network identifier (e.g. TESTNET or PUBLIC)
STELLAR_NETWORK="TESTNET"

# Soroban contract address used by on-chain integrations
SOROBAN_CONTRACT_ADDRESS="GXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# USDC asset details
USDC_ASSET_CODE="USDC"
USDC_ISSUER="GXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# Optional service port
PORT=3000
